{
  "description": "Per-shelter scraper config. listSelector MUST match only links to individual cat pages.",
  "sites": {
    "schroniskobelchatow.pl": {
      "listSelector": "a[href*='/adopcja,'][href$='.html']",
      "nameSelector": "h1",
      "nameCleanRegex": "^\\d+\\s+",
      "imageSelector": "img[src*='photo/adopcja/']:not([src*='_m.'])",
      "descSelector": "td p, p"
    },
