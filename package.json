{
  "name": "shelter-sync-cat-scraper",
  "version": "1.0.0",
  "description": "Temporal.io-based backend that synchronizes animal shelter data and scrapes cat listings",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "worker": "tsx src/worker.ts",
    "client": "tsx src/client.ts",
    "server": "tsx src/server.ts",
    "scrape": "tsx src/scrape-all.ts",
    "scrape-only": "tsx src/scraper-v4.ts",
    "validate": "tsx src/validate-data.ts",
    "test": "vitest --run"
  },
  "dependencies": {
    "@temporalio/activity": "^1.11.0",
    "@temporalio/client": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@temporalio/workflow": "^1.11.0",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/supertest": "^7.2.0",
    "fast-check": "^3.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "@swc/core@1.15.43": true,
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true,
    "protobufjs@7.6.2": true,
    "protobufjs@7.6.5": true
  }
}
